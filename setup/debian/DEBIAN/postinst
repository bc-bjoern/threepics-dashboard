#!/bin/bash
set -e  # Exit on any error

LOGFILE="/var/log/threepics-postinst.log"
exec >> "$LOGFILE" 2>&1

echo "➡ postinst started at $(date)"

FRONTEND_DIR="/opt/threepics/threepics-dashboard/frontend"
BACKEND_DIR="/opt/threepics/threepics-dashboard/backend"
BASHRC="/home/threepics/.bashrc"
BASH_PROFILE="/home/threepics/.bash_profile"
XINITRC="/home/threepics/.xinitrc"
CONFIG_FILE="/etc/default/threepics-dashboard"
DEFAULT_GIT_URL="https://github.com/bc-bjoern/threepics-dashboard.git"
VIMRC="/home/threepics/.vimrc"

# 1. Fix permissions for critical system files
chmod 440 /etc/sudoers.d/threepics
chown root:root /etc/sudoers.d/threepics
chown root:root /etc/systemd/system/threepics-frontend.service
chown root:root /etc/systemd/system/threepics-backend.service

# 2. Ensure 'threepics' user exists
if ! id -u threepics &>/dev/null; then
  useradd -m -s /bin/bash threepics
  echo "✅ Created user 'threepics'"
fi

# 3. Ensure home directory exists and is owned correctly
if [ ! -d /home/threepics ]; then
  mkdir -p /home/threepics
  chown threepics:threepics /home/threepics
  chmod 755 /home/threepics
fi

# 4. Create .xinitrc for X11 auto-start
cat << 'EOF' > "$XINITRC"
#!/bin/sh
xset -dpms
xset s off
xset s noblank

sleep 5

openbox-session &
unclutter -idle 0 &
chromium-browser --noerrdialogs --disable-infobars --kiosk http://localhost:38329
EOF

chmod 755 "$XINITRC"
chown threepics:threepics "$XINITRC"
echo "✅ .xinitrc created"

# 5. Create /opt/threepics and assign ownership
mkdir -p /opt/threepics
chown threepics:threepics /opt/threepics
chown threepics:threepics "$XINITRC"

# 6. Load Git URL from config or use default
if [ -f "$CONFIG_FILE" ]; then
  source "$CONFIG_FILE"
fi

GIT_REPO_URL="${GIT_REPO_URL:-$DEFAULT_GIT_URL}"
echo "📥 Using Git repository: $GIT_REPO_URL"

# 7. Clone the repo if not already present
if [ ! -d /opt/threepics/threepics-dashboard/.git ]; then
  runuser -u threepics -- git clone "$GIT_REPO_URL" /opt/threepics/threepics-dashboard
  echo "✅ Repository cloned"
fi

# 8. Create frontend .env file
cat > "$FRONTEND_DIR/.env" <<EOF
VITE_BACKEND_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:8081
EOF

chown threepics:threepics "$FRONTEND_DIR/.env"
chmod 644 "$FRONTEND_DIR/.env"
echo "✅ .env written to frontend"

# 9. Verify required tools
for bin in npm python3 pip3 git curl; do
  command -v "$bin" >/dev/null || { echo "❌ Missing required tool: $bin"; exit 1; }
done

# 10. Prepare PNPM environment
mkdir -p /home/threepics/.local/share/pnpm
chown -R threepics:threepics /home/threepics/.local
export PATH="/usr/local/bin:/usr/bin:/bin:/home/threepics/.local/bin:/home/threepics/.local/share/pnpm:$PATH"

# Ensure .bashrc exists
touch "$BASHRC"
chown threepics:threepics "$BASHRC"
chmod 644 "$BASHRC"

# Install pnpm
sudo -u threepics -H bash -c "curl -fsSL https://get.pnpm.io/install.sh | sh -" || {
  echo "❌ Failed to install pnpm"; exit 1;
}

# Add PNPM path to .bashrc if missing
if ! grep -q 'PNPM_HOME' "$BASHRC"; then
  echo 'export PNPM_HOME="$HOME/.local/share/pnpm"' >> "$BASHRC"
  echo 'export PATH="$PNPM_HOME:$HOME/.local/bin:$PATH"' >> "$BASHRC"
fi

# Verify pnpm works
runuser -u threepics -- pnpm --version || { echo "❌ pnpm check failed"; exit 1; }

# 11. Build frontend
if [ -d "$FRONTEND_DIR" ]; then
  echo "📦 Building frontend..."
  cd "$FRONTEND_DIR"
  mkdir -p /home/threepics/.local/bin
  chown -R threepics:threepics /home/threepics/.local
  runuser -u threepics -- pnpm install
  runuser -u threepics -- pnpm build
  runuser -u threepics -- pnpm config set global-bin-dir /home/threepics/.local/bin
  runuser -u threepics -- pnpm add serve -g
  SERVE_TARGET=$(find /home/threepics/.local/share/pnpm -path '*/serve/bin/serve.js' | head -n1)
  if [ -f "$SERVE_TARGET" ]; then
    ln -sf "$SERVE_TARGET" /home/threepics/.local/bin/serve
    chmod +x /home/threepics/.local/bin/serve
    chown threepics:threepics /home/threepics/.local/bin/serve
    echo "✅ Symlink created: serve → $SERVE_TARGET"
  else
    echo "⚠️ serve.js not found – pnpm install may have failed"
  fi
  runuser -u threepics -- pnpm setup
else
  echo "⚠️ Frontend directory not found"
fi

# 12. Setup Python backend
if [ -d "$BACKEND_DIR" ]; then
  echo "🐍 Setting up Python venv..."
  cd "$BACKEND_DIR"
  runuser -u threepics -- pnpm install
  python3 -m venv .venv
  source .venv/bin/activate
  pip install --upgrade pip
  pip install -r scripts/requirements.txt
  deactivate
else
  echo "⚠️ Backend directory not found"
fi

# 13. Enable and reload services
systemctl enable threepics-backend.service
systemctl enable threepics-frontend.service
systemctl daemon-reexec
systemctl daemon-reload
systemctl restart getty@tty1.service

# 14. Create user-friendly .vimrc
if [ ! -f "$VIMRC" ]; then
  cat << 'EOF' > "$VIMRC"
set expandtab
set tabstop=2
set shiftwidth=2
set softtabstop=2
set autoindent
set smartindent
syntax on
set number
EOF
  chown threepics:threepics "$VIMRC"
  echo "✅ .vimrc created"
fi

# 15. Create .bash_profile for startx autostart
cat << 'EOF' > "$BASH_PROFILE"
if [ -f ~/.bashrc ]; then
  . ~/.bashrc
fi

if [ -z "$DISPLAY" ] && [ "$(tty)" = "/dev/tty1" ]; then
  startx
fi
EOF
chown threepics:threepics "$BASH_PROFILE"
echo "✅ .bash_profile created"

# 16. Add useful aliases to .bashrc
grep -q "alias restart-backend=" "$BASHRC" || cat << 'EOF' >> "$BASHRC"

# === Useful Aliases ===
alias ll='ls -lh --color=auto'
alias cd-dashboard='cd /opt/threepics/threepics-dashboard && . backend/.venv/bin/activate'

# Service restart
alias restart-backend='sudo /bin/systemctl restart threepics-backend.service'
alias restart-frontend='sudo /bin/systemctl restart threepics-frontend.service'
alias restart-all='restart-backend && restart-frontend'

# Logs
alias logs-backend='sudo /bin/journalctl -u threepics-backend.service -n 50 --no-pager'
alias logs-frontend='sudo /bin/journalctl -u threepics-frontend.service -n 50 --no-pager'
alias logs-follow-backend='sudo /bin/journalctl -u threepics-backend.service -f'
alias logs-follow-frontend='sudo /bin/journalctl -u threepics-frontend.service -f'
EOF
chown threepics:threepics "$BASHRC"

# 17. Setup cronjobs if not already present
echo "📆 Configuring cronjobs..."
CRONTAB_TMP=$(mktemp)
crontab -u threepics -l 2>/dev/null > "$CRONTAB_TMP" || true

if ! grep -q 'git pull' "$CRONTAB_TMP"; then
  echo "@reboot cd /opt/threepics/threepics-dashboard && git pull >> /var/log/threepics-cron.log 2>&1" >> "$CRONTAB_TMP"
  echo "0 2 1 * * cd /opt/threepics/threepics-dashboard && git pull" >> "$CRONTAB_TMP"
  crontab -u threepics "$CRONTAB_TMP"
  echo "✅ Cronjobs added"
else
  echo "🔁 Cronjobs already exist – skipping"
fi

rm -f "$CRONTAB_TMP"

echo "🎉 postinst script completed successfully at $(date)"
exit 0
